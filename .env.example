# ==============================================================================
# AUDISYNC ENVIRONMENT CONFIGURATION
# Security Directive: NEVER commit .env to source control
# ==============================================================================

# ── EmailJS Configuration ──────────────────────────────────────────────────────
# Sign up free at https://www.emailjs.com
# 1. Create an Email Service (Gmail, Outlook, etc.)
# 2. Create an Email Template using these variables:
#      {{to_email}}, {{to_name}}, {{hall_name}}, {{hall_block}},
#      {{date}}, {{start_time}}, {{end_time}}, {{purpose}},
#      {{attendance}}, {{booking_id}}
# 3. Copy credentials from: Dashboard → Account → API Keys

VITE_EMAILJS_SERVICE_ID=service_xxxxxxx
VITE_EMAILJS_TEMPLATE_ID=template_xxxxxxx
VITE_EMAILJS_PUBLIC_KEY=xxxxxxxxxxxxxxxxxxxx
